---
import { site, nav, navExtra, whatsapps, waLink, socials } from "../data/site";
import Icon from "../components/Icon.astro";

const year = new Date().getFullYear();
const hasSocial = socials.some((s) => s.url !== "#");
---

<footer class="ft on-dark">
  <div class="container ft-inner">
    <nav class="ft-col" aria-label="Navegación del pie">
      <h4>Navegación</h4>
      <ul class="ft-navlist">
        {nav.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        {navExtra.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <div class="ft-col">
      <h4>Contacto</h4>
      <ul>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        {
          whatsapps.map((w) => (
            <li>
              <a href={waLink(w.intl)} target="_blank" rel="noopener">
                {w.label}: {w.display}
              </a>
            </li>
          ))
        }
        <li class="ft-addr">{site.address.full}</li>
      </ul>
    </div>

    {
      hasSocial && (
        <div class="ft-col">
          <h4>Síguenos</h4>
          <div class="ft-social">
            {socials.map((s) => (
              <a href={s.url} target="_blank" rel="noopener" aria-label={s.label}>
                <Icon name={s.icon} size={18} />
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>

  <div class="container ft-bottom">
    <p>© {year} {site.legalName} · RUC {site.ruc}</p>
  </div>
</footer>

<style>
  .ft {
    background: var(--ink-2);
    border-top: 1px solid var(--line);
  }
  .ft-inner {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2rem);
    grid-template-columns: 1fr;
    padding-block: clamp(1.6rem, 3vw, 2.2rem) 1.2rem;
  }
  .ft-social {
    display: flex;
    gap: 0.6rem;
  }
  .ft-social a {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: var(--radius);
    border: 1px solid var(--line-strong);
    color: var(--text-muted);
    transition: color var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      background var(--dur) var(--ease-out);
  }
  .ft-social a:hover {
    background: var(--amber-tint);
  }
  .ft-social a:hover {
    color: var(--amber);
    border-color: var(--amber-line);
  }
  .ft-col h4 {
    font-size: 0.92rem;
    letter-spacing: 0.06em;
    color: var(--text);
    margin-bottom: 0.9rem;
  }
  .ft-col ul {
    display: grid;
    gap: 0.55rem;
  }
  .ft-navlist {
    grid-template-columns: 1fr 1fr;
    column-gap: 1.4rem;
  }
  .ft-col a {
    color: var(--text-dim);
    font-size: 0.92rem;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .ft-col a:hover {
    color: var(--amber);
  }
  .ft-addr {
    color: var(--text-dim);
    font-size: 0.88rem;
    max-width: 30ch;
  }
  .ft-bottom {
    text-align: center;
    padding-block: 1rem 1.3rem;
    color: var(--text-dim);
    font-size: 0.84rem;
  }

  @media (min-width: 760px) {
    .ft-inner {
      grid-template-columns: 1.6fr 1.4fr 0.8fr;
      align-items: start;
    }
  }
</style>
