---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  image: ImageMetadata;
  pos?: string;
}
const { title, subtitle, eyebrow, image, pos = "center 40%" } = Astro.props;
---

<section class="phero on-dark" aria-labelledby="phero-h">
  <div class="phero-media" aria-hidden="true">
    <Image src={image} alt="" widths={[768, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" style={`object-position:${pos}`} />
    <span class="phero-scrim"></span>
  </div>
  <div class="hazard-bar phero-hazard" aria-hidden="true"></div>
  <div class="container phero-inner">
    <h1 id="phero-h" set:html={title} />
    {subtitle && <p class="phero-sub">{subtitle}</p>}
  </div>
</section>

<style>
  .phero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: clamp(440px, 64vw, 660px);
    display: grid;
    align-items: center;
    text-align: center;
  }
  .phero-media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .phero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .phero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(var(--ink-rgb), 0.84),
      rgba(var(--ink-rgb), 0.74)
    );
  }
  .phero-hazard {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
  }
  .phero-inner {
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .phero-inner .eyebrow {
    margin-bottom: 0.6rem;
  }
  .phero-inner h1 {
    font-size: clamp(1.9rem, 1.3rem + 3.2vw, 3.2rem);
    text-transform: uppercase;
    letter-spacing: 0.01em;
    text-wrap: balance;
  }
  .phero-sub {
    margin-top: 0.7rem;
    color: #d7dce4;
    font-size: clamp(0.95rem, 0.9rem + 0.3vw, 1.1rem);
    max-width: 60ch;
    margin-inline: auto;
  }
</style>
