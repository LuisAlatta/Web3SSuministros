---
import Icon from "./Icon.astro";

/* Guía técnica desplegable que se incrusta dentro de un producto/línea.
   Recibe una guía de `guias` (data/content). */
interface Bloque {
  readonly p?: string;
  readonly h?: string;
  readonly li?: readonly string[];
}
interface GuiaData {
  readonly title: string;
  readonly categoria: string;
  readonly lectura: number;
  readonly resumen: string;
  readonly bloques: readonly Bloque[];
}
interface Props {
  guia: GuiaData;
  open?: boolean;
}
const { guia, open = false } = Astro.props;
---

<details class="guia" open={open}>
  <summary>
    <span class="guia-ic"><Icon name="doc" size={18} /></span>
    <span class="guia-sum">
      <span class="guia-kicker">
        Guía técnica <span class="guia-cat">{guia.categoria}</span>
        <span class="guia-read">{guia.lectura} min</span>
      </span>
      <span class="guia-title">{guia.title}</span>
    </span>
    <span class="guia-chev" aria-hidden="true"><Icon name="arrowdown" size={18} /></span>
  </summary>

  <div class="guia-body">
    <p class="guia-lead">{guia.resumen}</p>
    {
      guia.bloques.map((b) =>
        b.h ? (
          <h4>{b.h}</h4>
        ) : b.li ? (
          <ul>
            {b.li.map((item) => (
              <li>
                <Icon name="check" size={15} /> {item}
              </li>
            ))}
          </ul>
        ) : (
          <p>{b.p}</p>
        )
      )
    }
  </div>
</details>

<style>
  .guia {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--steel-900);
    overflow: hidden;
  }
  .guia + :global(.guia) {
    margin-top: 0.8rem;
  }
  .guia summary {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem 1.1rem;
    cursor: pointer;
    list-style: none;
    transition: background var(--dur) var(--ease-out);
  }
  .guia summary::-webkit-details-marker {
    display: none;
  }
  .guia summary:hover {
    background: var(--steel-850);
  }
  .guia-ic {
    flex: none;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius);
    background: var(--amber-tint);
    color: var(--amber-deep);
  }
  .guia-sum {
    display: grid;
    gap: 0.25rem;
    min-width: 0;
  }
  .guia-kicker {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.68rem;
    color: var(--text-dim);
  }
  .guia-cat {
    color: var(--on-amber);
    background: var(--amber);
    border-radius: var(--radius-xs);
    padding: 0.14rem 0.4rem;
    letter-spacing: 0.03em;
  }
  .guia-read {
    color: var(--text-dim);
  }
  .guia-title {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    font-size: clamp(0.95rem, 0.9rem + 0.3vw, 1.08rem);
    color: var(--text);
    line-height: 1.25;
  }
  .guia-chev {
    flex: none;
    margin-left: auto;
    display: grid;
    place-items: center;
    color: var(--text-dim);
    transition: transform var(--dur) var(--ease-out), color var(--dur) var(--ease-out);
  }
  .guia[open] .guia-chev {
    transform: rotate(180deg);
    color: var(--amber);
  }

  .guia-body {
    padding: 0 1.1rem 1.3rem;
  }
  .guia-lead {
    color: var(--text-muted);
    font-size: 0.95rem;
    padding: 0.2rem 0 0.9rem;
    margin-bottom: 0.6rem;
    border-bottom: 1px solid var(--line);
  }
  .guia-body h4 {
    font-family: var(--font-display);
    text-transform: none;
    font-size: 1rem;
    color: var(--text);
    margin: 1.1rem 0 0.4rem;
  }
  .guia-body p {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
    margin-bottom: 0.6rem;
  }
  .guia-body ul {
    display: grid;
    gap: 0.45rem;
    margin: 0.3rem 0 0.8rem;
  }
  .guia-body li {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .guia-body li :global(svg) {
    color: var(--amber);
    flex: none;
    margin-top: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .guia-chev {
      transition: none;
    }
  }
</style>
