---
import { whatsapps, waLink } from "../data/site";
import Icon from "./Icon.astro";
---

<div class="fab" data-fab>
  <div class="fab-menu" data-fab-menu hidden role="menu">
    <p class="fab-title">Elige con quién hablar</p>
    {
      whatsapps.map((w) => (
        <a
          class="fab-item"
          href={waLink(w.intl)}
          target="_blank"
          rel="noopener"
          role="menuitem"
        >
          <span class="fab-ic"><Icon name="whatsapp" size={20} /></span>
          <span class="fab-txt">
            <strong>{w.label}</strong>
            <em>{w.display}</em>
          </span>
        </a>
      ))
    }
  </div>

  <button
    class="fab-btn"
    aria-label="Contactar por WhatsApp"
    aria-expanded="false"
    data-fab-btn
  >
    <svg class="fab-logo" viewBox="0 0 24 24" width="34" height="34" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.885-9.885 9.885m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
    <span class="fab-pulse"></span>
  </button>
</div>

<script is:inline>
  (() => {
    const fab = document.querySelector("[data-fab]");
    const btn = document.querySelector("[data-fab-btn]");
    const menu = document.querySelector("[data-fab-menu]");
    const toggle = (open) => {
      menu.hidden = !open;
      btn.setAttribute("aria-expanded", String(open));
      fab.toggleAttribute("data-open", open);
    };
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle(btn.getAttribute("aria-expanded") !== "true");
    });
    document.addEventListener("click", (e) => {
      if (!fab.contains(e.target)) toggle(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") toggle(false);
    });
  })();
</script>

<style>
  .fab {
    position: fixed;
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 120;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.85rem;
  }
  .fab-btn {
    position: relative;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: #25d366;
    color: #fff;
    display: grid;
    place-items: center;
    box-shadow: 0 14px 30px -8px rgba(37, 211, 102, 0.55);
    transition: transform var(--dur) var(--ease-out);
  }
  .fab-btn:hover {
    transform: scale(1.06);
  }
  .fab[data-open] .fab-btn {
    transform: rotate(8deg);
  }
  .fab-pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid #25d366;
    animation: fabpulse 2.4s var(--ease-out) infinite;
  }
  @keyframes fabpulse {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    70%,
    100% {
      transform: scale(1.7);
      opacity: 0;
    }
  }
  .fab-menu {
    width: min(280px, 78vw);
    background: var(--steel-850);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-lg);
    padding: 0.9rem;
    box-shadow: var(--shadow-card);
    display: grid;
    gap: 0.4rem;
    transform-origin: bottom right;
    animation: fabin var(--dur) var(--ease-out);
  }
  @keyframes fabin {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.96);
    }
  }
  .fab-title {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: 0.78rem;
    color: var(--text-dim);
    padding: 0.2rem 0.4rem 0.5rem;
  }
  .fab-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.65rem 0.6rem;
    border-radius: var(--radius);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .fab-item:hover {
    background: var(--steel-700);
  }
  .fab-ic {
    width: 38px;
    height: 38px;
    flex: none;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(37, 211, 102, 0.14);
    color: #25d366;
  }
  .fab-txt {
    display: grid;
    line-height: 1.25;
  }
  .fab-txt strong {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.86rem;
  }
  .fab-txt em {
    font-style: normal;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .fab-pulse {
      animation: none;
    }
  }
</style>
