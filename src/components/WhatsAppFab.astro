---
import { whatsapps, waLink } from "../data/site";
import Icon from "./Icon.astro";
---

<div class="fab" data-fab>
  <div class="fab-menu" data-fab-menu hidden role="menu">
    <p class="fab-title">Elige con quién hablar</p>
    {
      whatsapps.map((w) => (
        <a
          class="fab-item"
          href={waLink(w.intl)}
          target="_blank"
          rel="noopener"
          role="menuitem"
        >
          <span class="fab-ic"><Icon name="whatsapp" size={20} /></span>
          <span class="fab-txt">
            <strong>{w.label}</strong>
            <em>{w.display}</em>
          </span>
        </a>
      ))
    }
  </div>

  <button
    class="fab-btn"
    aria-label="Contactar por WhatsApp"
    aria-expanded="false"
    data-fab-btn
  >
    <Icon name="whatsapp" size={30} />
    <span class="fab-pulse"></span>
  </button>
</div>

<script is:inline>
  (() => {
    const fab = document.querySelector("[data-fab]");
    const btn = document.querySelector("[data-fab-btn]");
    const menu = document.querySelector("[data-fab-menu]");
    const toggle = (open) => {
      menu.hidden = !open;
      btn.setAttribute("aria-expanded", String(open));
      fab.toggleAttribute("data-open", open);
    };
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle(btn.getAttribute("aria-expanded") !== "true");
    });
    document.addEventListener("click", (e) => {
      if (!fab.contains(e.target)) toggle(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") toggle(false);
    });
  })();
</script>

<style>
  .fab {
    position: fixed;
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 120;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.85rem;
  }
  .fab-btn {
    position: relative;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: #25d366;
    color: #06351a;
    display: grid;
    place-items: center;
    box-shadow: 0 14px 30px -8px rgba(37, 211, 102, 0.55);
    transition: transform var(--dur) var(--ease-out);
  }
  .fab-btn:hover {
    transform: scale(1.06);
  }
  .fab[data-open] .fab-btn {
    transform: rotate(8deg);
  }
  .fab-pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid #25d366;
    animation: fabpulse 2.4s var(--ease-out) infinite;
  }
  @keyframes fabpulse {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    70%,
    100% {
      transform: scale(1.7);
      opacity: 0;
    }
  }
  .fab-menu {
    width: min(280px, 78vw);
    background: var(--steel-850);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-lg);
    padding: 0.9rem;
    box-shadow: var(--shadow-card);
    display: grid;
    gap: 0.4rem;
    transform-origin: bottom right;
    animation: fabin var(--dur) var(--ease-out);
  }
  @keyframes fabin {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.96);
    }
  }
  .fab-title {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: 0.78rem;
    color: var(--text-dim);
    padding: 0.2rem 0.4rem 0.5rem;
  }
  .fab-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.65rem 0.6rem;
    border-radius: var(--radius);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .fab-item:hover {
    background: var(--steel-700);
  }
  .fab-ic {
    width: 38px;
    height: 38px;
    flex: none;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(37, 211, 102, 0.14);
    color: #25d366;
  }
  .fab-txt {
    display: grid;
    line-height: 1.25;
  }
  .fab-txt strong {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.86rem;
  }
  .fab-txt em {
    font-style: normal;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .fab-pulse {
      animation: none;
    }
  }
</style>
