---
/* Íconos SVG inline. Stroke = currentColor. */
interface Props {
  name: string;
  size?: number;
  class?: string;
  fill?: boolean;
}
const { name, size = 24, class: cls = "", fill = false } = Astro.props;

const paths: Record<string, string> = {
