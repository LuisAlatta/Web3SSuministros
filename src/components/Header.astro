---
import { Image } from "astro:assets";
import logo from "../assets/logo/logo-3s-badge.png";
import { nav, whatsapps, waLink } from "../data/site";
import Icon from "./Icon.astro";

const path = (Astro.url.pathname.replace(/\/+$/, "") || "/").toLowerCase();
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="hdr" data-header>
  <div class="hdr-inner container-wide">
    <a href="/" class="hdr-logo" aria-label="3S Suministros — Inicio">
      <Image
        src={logo}
        alt="3S Suministros y Servicios del Sur"
        width={180}
        densities={[1.5, 2]}
        loading="eager"
      />
    </a>

    <nav class="hdr-nav" aria-label="Navegación principal">
      {
        nav.map((l) => (
          <a href={l.href} aria-current={isActive(l.href) ? "page" : undefined}>
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="hdr-actions">
      <a
        class="btn btn-amber btn-sm"
        href={waLink(whatsapps[0].intl)}
        target="_blank"
        rel="noopener"
      >
        <Icon name="whatsapp" size={18} />
        Cotizar
      </a>
      <button
        class="hdr-burger"
        aria-label="Abrir menú"
        aria-expanded="false"
        data-burger
      >
        <Icon name="menu" size={26} />
      </button>
    </div>
  </div>

  <!-- Panel móvil -->
  <div class="hdr-mobile" data-mobile hidden>
    <nav aria-label="Navegación móvil">
      {
        nav.map((l) => (
          <a href={l.href} data-mlink aria-current={isActive(l.href) ? "page" : undefined}>
            {l.label}
          </a>
        ))
      }
    </nav>
    <a
      class="btn btn-amber"
      href={waLink(whatsapps[0].intl)}
      target="_blank"
      rel="noopener"
      data-mlink
    >
      <Icon name="whatsapp" size={18} /> Escribir por WhatsApp
    </a>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-header]");
    const burger = document.querySelector("[data-burger]");
    const panel = document.querySelector("[data-mobile]");

    const onScroll = () => {
      if (window.scrollY > 24) header.setAttribute("data-scrolled", "");
      else header.removeAttribute("data-scrolled");
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    const setOpen = (open) => {
      panel.hidden = !open;
      burger.setAttribute("aria-expanded", String(open));
      document.body.style.overflow = open ? "hidden" : "";
    };
    burger?.addEventListener("click", () =>
      setOpen(burger.getAttribute("aria-expanded") !== "true")
    );
    document
      .querySelectorAll("[data-mlink]")
      .forEach((a) => a.addEventListener("click", () => setOpen(false)));
  })();
</script>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    transition: background var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .hdr[data-scrolled] {
    background: rgba(245, 246, 248, 0.85);
    backdrop-filter: blur(12px);
    box-shadow: var(--shadow-sm);
  }
  .hdr-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 72px;
  }
  .hdr-logo {
    display: inline-flex;
    align-items: center;
  }
  .hdr-logo img {
    height: 56px;
    width: auto;
    transition: transform var(--dur) var(--ease-out);
  }
  .hdr-logo:hover img {
    transform: scale(1.04);
  }
  .hdr-nav {
    display: none;
    gap: clamp(0.7rem, 1.1vw, 1.35rem);
    margin-inline-start: auto;
    margin-inline-end: 0.5rem;
  }
  .hdr-nav a {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    position: relative;
    padding-block: 0.4rem;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .hdr-nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    height: 2px;
    width: 0;
    background: var(--amber);
    transition: width var(--dur) var(--ease-out);
  }
  .hdr-nav a:hover,
  .hdr-nav a[aria-current="page"] {
    color: var(--text);
  }
  .hdr-nav a:hover::after,
  .hdr-nav a[aria-current="page"]::after {
    width: 100%;
  }
  .hdr-nav a[aria-current="page"] {
    color: var(--amber);
  }
  .hdr-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-sm {
    --btn-pad-y: 0.6rem;
    --btn-pad-x: 1.1rem;
    font-size: 0.85rem;
  }
  .hdr-burger {
    display: inline-grid;
    place-items: center;
    background: transparent;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    color: var(--text);
    width: 44px;
    height: 44px;
    cursor: pointer;
  }
  .hdr-mobile {
    border-top: 1px solid var(--line);
    background: var(--steel-900);
    padding: 1.2rem var(--gutter) 1.6rem;
    display: grid;
    gap: 1rem;
  }
  .hdr-mobile nav {
    display: grid;
    gap: 0.2rem;
  }
  .hdr-mobile nav a {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 1.1rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--line);
    color: var(--text);
  }
  .hdr-mobile nav a[aria-current="page"] {
    color: var(--amber);
  }

  @media (min-width: 1000px) {
    .hdr-nav {
      display: flex;
    }
    .hdr-burger,
    .hdr-mobile {
      display: none;
    }
  }
</style>
