---
import Page from "../../layouts/Page.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import CtaBand from "../../components/CtaBand.astro";
import Icon from "../../components/Icon.astro";
import { novedades } from "../../data/content";
import { site, whatsapps, waLink } from "../../data/site";
import { formatFecha } from "../../lib/format";

export function getStaticPaths() {
  return novedades.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const otras = novedades.filter((p) => p.slug !== post.slug).slice(0, 3);
---

<Page
  title={`${post.title} | ${site.shortName}`}
  description={post.resumen}
>
  <Breadcrumb current="Novedades" />

  <article class="section art">
    <div class="container art-wrap">
      <header class="art-head reveal">
        <div class="art-meta">
          <span class="art-cat">{post.categoria}</span>
          <time datetime={post.fecha}>{formatFecha(post.fecha)}</time>
          <span class="art-read">{post.lectura} min de lectura</span>
        </div>
        <h1>{post.title}</h1>
        <p class="art-lead">{post.resumen}</p>
      </header>

      <div class="art-body reveal">
        {
          post.bloques.map((b) =>
            "h" in b ? (
              <h2>{b.h}</h2>
            ) : "li" in b ? (
              <ul>
                {b.li.map((item) => (
                  <li>
                    <Icon name="check" size={16} /> {item}
                  </li>
                ))}
              </ul>
            ) : (
              <p>{b.p}</p>
            )
          )
        }
      </div>

      <div class="art-cta reveal">
        <div>
          <strong>¿Necesitas asesoría sobre este tema?</strong>
          <span>Nuestro equipo técnico te ayuda a elegir el producto correcto.</span>
        </div>
        <a
          class="btn btn-amber"
          href={waLink(whatsapps[0].intl, `Hola 3S, leí "${post.title}" en su web y quiero asesoría.`)}
          target="_blank"
          rel="noopener"
        >
          Consultar
        </a>
      </div>

      {
        otras.length > 0 && (
          <div class="art-more reveal">
            <p class="art-more-h">Sigue leyendo</p>
            <ul>
              {otras.map((o) => (
                <li>
                  <a href={`/novedades/${o.slug}`}>
                    <span>{o.categoria}</span>
                    {o.title}
                    <Icon name="arrow" size={16} />
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <a class="art-back" href="/novedades">
        <Icon name="arrow" size={16} class="art-back-ic" /> Volver a Novedades
      </a>
    </div>
  </article>

  <CtaBand />
</Page>

<style>
  .art-wrap {
    max-width: 780px;
  }
  .art-head {
    margin-bottom: clamp(1.8rem, 4vw, 2.6rem);
  }
  .art-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 0.9rem;
    margin-bottom: 1.1rem;
  }
  .art-cat {
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--on-amber);
    background: var(--amber);
    border-radius: var(--radius-xs);
    padding: 0.24rem 0.6rem;
  }
  .art-meta time,
  .art-read {
    font-size: 0.82rem;
    color: var(--text-dim);
    font-family: var(--font-display);
    letter-spacing: 0.03em;
  }
  .art-head h1 {
    font-size: clamp(1.9rem, 1.3rem + 3vw, 3rem);
    line-height: 1.1;
    text-wrap: balance;
    margin-bottom: 1rem;
  }
  .art-lead {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  .art-body :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1rem + 1vw, 1.6rem);
    margin: 2rem 0 0.8rem;
    color: var(--text);
  }
  .art-body :global(p) {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .art-body :global(ul) {
    display: grid;
    gap: 0.6rem;
    margin: 0.4rem 0 1.4rem;
  }
  .art-body :global(li) {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .art-body :global(li svg) {
    color: var(--amber);
    flex: none;
    margin-top: 5px;
  }

  .art-cta {
    display: grid;
    gap: 1.1rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    padding: clamp(1.5rem, 3vw, 2rem);
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-lg);
    background: linear-gradient(120deg, var(--amber-tint), transparent 75%);
  }
  .art-cta strong {
    display: block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
  }
  .art-cta span {
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .art-more {
    margin-top: clamp(2.2rem, 4vw, 3rem);
    border-top: 1px solid var(--line);
    padding-top: 1.6rem;
  }
  .art-more-h {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--text-dim);
    font-size: 0.82rem;
    margin-bottom: 1rem;
  }
  .art-more ul {
    display: grid;
    gap: 0.6rem;
  }
  .art-more a {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--steel-900);
    color: var(--text);
    font-family: var(--font-display);
    letter-spacing: 0.01em;
    transition: border-color var(--dur) var(--ease-out), transform var(--dur) var(--ease-out);
  }
  .art-more a:hover {
    border-color: var(--amber-line);
    transform: translateX(3px);
  }
  .art-more a span {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--amber-deep);
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-xs);
    padding: 0.18rem 0.45rem;
    flex: none;
  }
  .art-more a :global(svg) {
    margin-left: auto;
    color: var(--amber);
    flex: none;
  }

  .art-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .art-back:hover {
    color: var(--amber);
  }
  .art-back :global(.art-back-ic) {
    transform: rotate(180deg);
  }

  @media (min-width: 620px) {
    .art-cta {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }
</style>
