---
import Page from "../layouts/Page.astro";
import PageHero from "../components/PageHero.astro";
import heroImg from "../assets/img/ln-herramientas.jpg";
import Categorias from "../sections/Categorias.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";
---

<Page
  title={`Categorías de negocio | ${site.shortName}`}
  description="Seis líneas de productos industriales: herramientas, seguridad industrial, equipos eléctricos, izaje, transmisión de potencia y ferretería."
>
  <PageHero
    image={heroImg}
    eyebrow="Categorías de negocio"
    title='Todo lo que tu operación <span class="amber">necesita</span>'
    subtitle="Seis grandes líneas de productos industriales, en un solo proveedor"
    pos="center 50%"
  />
  <Categorias />
  <CtaBand />
</Page>
