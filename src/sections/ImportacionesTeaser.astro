---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Icon from "../components/Icon.astro";
import { importaciones } from "../data/content";

const imgs = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/img/importaciones/*.{jpg,jpeg,png,webp}",
  { eager: true }
);
const img = (name: string) =>
  imgs[`../assets/img/importaciones/${name}.jpg`]?.default;

const lineas = importaciones.lineas;
---

<section class="section plate" aria-labelledby="impt-h">
  <div class="container">
    <header class="impt-head reveal">
      <div>
        <p class="eyebrow">Líneas de importación</p>
        <h2 id="impt-h">Productos de <span class="amber">importación</span></h2>
      </div>
      <a class="btn btn-ghost" href="/importaciones">
        Ver todas <Icon name="arrow" size={18} />
      </a>
    </header>

    <div class="impt-grid">
      {
        lineas.map((l, i) => (
          <a
            href={`/importaciones#${l.id}`}
            class={`impt-card reveal reveal-${(i % 3) + 1}`}
          >
            <div class="impt-media">
              {img(l.img) && (
                <Image
                  src={img(l.img)!}
                  alt={l.nombre}
                  widths={[360, 560]}
                  sizes="(min-width: 760px) 32vw, 100vw"
                />
              )}
              <span class="impt-brand">{l.marca}</span>
            </div>
            <div class="impt-body">
              <h3>{l.nombre}</h3>
              <p>{l.tagline}</p>
              <span class="impt-link">
                Ver línea <Icon name="arrow" size={16} />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .impt-head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .impt-head h2 {
    margin-top: 0.9rem;
  }
  .impt-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }
  .impt-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--steel-900);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .impt-card:hover {
    transform: translateY(-4px);
    border-color: var(--amber-line);
    box-shadow: var(--shadow-card);
  }
  .impt-media {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #fff;
    overflow: hidden;
  }
  .impt-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .impt-card:hover .impt-media img {
    transform: scale(1.05);
  }
  .impt-brand {
    position: absolute;
    left: 0.7rem;
    bottom: 0.7rem;
    font-family: var(--font-display);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--on-amber);
    background: var(--amber);
    border-radius: var(--radius-xs);
    padding: 0.24rem 0.55rem;
  }
  .impt-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: clamp(1.1rem, 3vw, 1.5rem);
  }
  .impt-body h3 {
    font-size: 1.12rem;
    line-height: 1.3;
    margin-bottom: 0.45rem;
  }
  .impt-body p {
    color: var(--text-muted);
    font-size: 0.9rem;
    flex: 1;
    margin-bottom: 1rem;
  }
  .impt-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.8rem;
    color: var(--amber-deep);
  }
  .impt-link :global(svg) {
    transition: transform var(--dur) var(--ease-out);
  }
  .impt-card:hover .impt-link :global(svg) {
    transform: translateX(4px);
  }

  @media (min-width: 760px) {
    .impt-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
