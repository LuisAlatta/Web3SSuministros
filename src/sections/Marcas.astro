---
import { marcaPrincipal, marcasPorRubro } from "../data/content";
import { whatsapps, waLink } from "../data/site";
import Icon from "../components/Icon.astro";
---

<section id="marcas" class="section" aria-labelledby="mar-h">
  <div class="container">
    <header class="mar-head reveal">
      <p class="eyebrow">Marcas que representamos</p>
      <h2 id="mar-h">Respaldados por las <span class="amber">mejores marcas</span></h2>
    </header>

    <!-- Bekaert destacado -->
    <article class="bekaert reveal on-dark">
      <div class="bekaert-glow" aria-hidden="true"></div>
      <div class="bekaert-body">
        <span class="bekaert-badge">Marca destacada</span>
        <p class="bekaert-name">{marcaPrincipal.name}</p>
        <p class="bekaert-claim">"{marcaPrincipal.claim}"</p>
        <p class="bekaert-desc">{marcaPrincipal.description}</p>
        <a
          class="btn btn-amber"
          href={waLink(whatsapps[0].intl, "Hola 3S, quiero consultar por elementos de izaje Bekaert.")}
          target="_blank"
          rel="noopener"
        >
          <Icon name="whatsapp" size={18} /> Consultar productos Bekaert
        </a>
      </div>
      <ul class="bekaert-points">
        {
          marcaPrincipal.points.map((p) => (
            <li>
              <Icon name="check" size={18} /> {p}
            </li>
          ))
        }
      </ul>
    </article>

    <p class="mar-sub reveal">También trabajamos con marcas líderes</p>
    <div class="mar-rubros">
      {
        marcasPorRubro.map((g, i) => (
          <div class={`mar-rubro reveal reveal-${(i % 3) + 1}`}>
            <h3>{g.rubro}</h3>
            <ul class="mar-wall">
              {g.marcas.map((m) => <li>{m}</li>)}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .mar-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .mar-head h2 {
    margin-top: 0.9rem;
  }

  .bekaert {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: clamp(1.8rem, 4vw, 3rem);
    padding: clamp(1.8rem, 4vw, 3.4rem);
    border-radius: var(--radius-xl);
    border: 1px solid var(--amber-line);
    background: linear-gradient(150deg, var(--ink-2), var(--ink) 85%);
    box-shadow: var(--shadow-lg);
  }
  .bekaert-glow {
    position: absolute;
    top: -40%;
    right: -10%;
    width: 480px;
    height: 480px;
    background: radial-gradient(circle, rgba(244, 168, 29, 0.18), transparent 60%);
    pointer-events: none;
  }
  .bekaert-body {
    position: relative;
    z-index: 1;
  }
  .bekaert-badge {
    display: inline-block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: 0.74rem;
    color: var(--on-amber);
    background: var(--amber);
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-xs);
    margin-bottom: 1.1rem;
  }
  .bekaert-name {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(2.6rem, 1.5rem + 4vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
  }
  .bekaert-claim {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1rem + 0.8vw, 1.6rem);
    color: var(--amber);
    margin: 0.8rem 0 1.2rem;
    font-style: italic;
  }
  .bekaert-desc {
    color: var(--text-muted);
    max-width: 56ch;
    margin-bottom: 1.8rem;
  }
  .bekaert-points {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.9rem;
    align-content: center;
  }
  .bekaert-points li {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    font-family: var(--font-display);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.98rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--line);
  }
  .bekaert-points li :global(svg) {
    color: var(--amber);
    flex: none;
    margin-top: 1px;
  }

  .mar-sub {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--text-dim);
    font-size: 0.82rem;
    margin: clamp(2.4rem, 4vw, 3.4rem) 0 1.1rem;
  }
  .mar-rubros {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }
  .mar-rubro {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: clamp(1.3rem, 3vw, 1.8rem);
    background: var(--steel-900);
    box-shadow: var(--shadow-sm);
  }
  .mar-rubro h3 {
    font-size: 0.82rem;
    letter-spacing: var(--tracking-wide);
    color: var(--amber-deep);
    margin-bottom: var(--space-md);
  }
  .mar-wall {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .mar-wall li {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.88rem;
    color: var(--text);
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-xs);
    transition: border-color var(--dur) var(--ease-out),
      color var(--dur) var(--ease-out);
  }
  .mar-wall li:hover {
    border-color: var(--amber);
    color: var(--amber-deep);
  }

  @media (min-width: 860px) {
    .bekaert {
      grid-template-columns: 1.3fr 0.7fr;
      align-items: center;
    }
    .mar-rubros {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
