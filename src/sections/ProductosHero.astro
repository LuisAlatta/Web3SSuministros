---
import { Image } from "astro:assets";
import fondo from "../assets/img/equipo.jpg";
---

<section class="phero on-dark" aria-labelledby="phero-h">
  <div class="phero-media" aria-hidden="true">
    <Image src={fondo} alt="" widths={[768, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" />
    <span class="phero-scrim"></span>
  </div>
  <div class="container phero-inner">
    <h1 id="phero-h">Cotiza nuestros <span class="amber">productos</span></h1>
    <p>Calidad y precios competitivos · Entregas a todo el Perú</p>
  </div>
</section>

<style>
  .phero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: clamp(220px, 34vw, 340px);
    display: grid;
    align-items: center;
    text-align: center;
  }
  .phero-media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .phero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .phero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(var(--ink-rgb), 0.82),
      rgba(var(--ink-rgb), 0.72)
    );
  }
  .phero-inner {
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .phero-inner h1 {
    font-size: clamp(2rem, 1.3rem + 3.5vw, 3.4rem);
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }
  .phero-inner p {
    margin-top: 0.6rem;
    color: #d7dce4;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: clamp(0.82rem, 0.75rem + 0.4vw, 1rem);
  }
</style>
