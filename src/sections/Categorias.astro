---
import { categorias } from "../data/content";
import { whatsapps, waLink } from "../data/site";
import Icon from "../components/Icon.astro";
---

<section id="categorias" class="section plate" aria-label="Categorías de negocio">
  <div class="container">
    <div class="cat-grid">
      {
        categorias.map((c, i) => (
          <article class={`cat-card reveal reveal-${(i % 3) + 1}`}>
            <div class="cat-card-top">
              <span class="cat-num">{`0${i + 1}`}</span>
              <span class="cat-ic"><Icon name={c.icon} size={22} /></span>
            </div>
            <h3>{c.title}</h3>
            <span class="cat-rule" aria-hidden="true" />
            <ul>
              {c.items.map((it) => (
                <li>
                  <Icon name="check" size={15} /> {it}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>

    <div class="cat-cta reveal">
      <p>¿No ves lo que buscas? Tenemos acceso a mucho más.</p>
      <a
        class="btn btn-amber"
        href={waLink(whatsapps[1].intl, "Hola 3S, necesito un producto que no veo en la web. ¿Pueden ayudarme a conseguirlo?")}
        target="_blank"
        rel="noopener"
      >
        Consultar disponibilidad
      </a>
    </div>
  </div>
</section>

<style>
  .cat-head {
    max-width: 760px;
    margin-bottom: clamp(2.5rem, 5vw, 3.8rem);
  }
  .cat-head h2 {
    margin: 0.9rem 0 1.2rem;
  }
  .cat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }
  .cat-card {
    background: var(--steel-900);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2.1rem);
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .cat-card:hover {
    transform: translateY(-4px);
    border-color: var(--amber-line);
    box-shadow: var(--shadow-card);
  }
  .cat-card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .cat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 1.9rem + 1.6vw, 3.1rem);
    line-height: 0.9;
    color: var(--amber-deep);
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
  }
  .cat-ic {
    color: var(--text-dim);
    transition: color var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .cat-card:hover .cat-ic {
    color: var(--amber);
    transform: translateY(-2px);
  }
  .cat-card h3 {
    font-size: 1.28rem;
    margin-top: var(--space-md);
  }
  .cat-rule {
    display: block;
    height: 3px;
    width: 34px;
    margin: 0.85rem 0 1.1rem;
    background: var(--amber);
    border-radius: 2px;
    transition: width var(--dur) var(--ease-out);
  }
  .cat-card:hover .cat-rule {
    width: 60px;
  }
  .cat-card ul {
    display: grid;
    gap: 0.55rem;
  }
  .cat-card li {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .cat-card li :global(svg) {
    color: var(--amber);
    margin-top: 3px;
    flex: none;
  }

  .cat-cta {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
    padding: clamp(1.4rem, 3vw, 2rem);
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-lg);
    background: linear-gradient(
      100deg,
      var(--amber-tint),
      transparent 70%
    );
  }
  .cat-cta p {
    font-family: var(--font-display);
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  @media (min-width: 640px) {
    .cat-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1000px) {
    .cat-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
