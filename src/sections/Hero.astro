---
import { Image } from "astro:assets";
import heroImg from "../assets/img/hero-mina.jpg";
import { whatsapps, waLink } from "../data/site";
import { normativas } from "../data/content";
import Icon from "../components/Icon.astro";
---

<section id="inicio" class="hero on-dark" aria-labelledby="hero-h">
  <div class="hero-media" aria-hidden="true">
    <Image
      src={heroImg}
      alt=""
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-scrim"></div>
  </div>

  <div class="container hero-inner">
    <p class="eyebrow reveal">Suministros industriales · Arequipa · Perú</p>
    <h1 id="hero-h" class="hero-title reveal reveal-2">
      El socio <span class="amber">estratégico</span> para tu empresa
    </h1>
    <p class="lead reveal reveal-3">
      Abastecemos suministros industriales para minería, construcción, petróleo,
      gas, energía e industria. Representantes de <strong>Bekaert</strong> y
      distribuidores de marcas líderes, con entregas a todo el Perú.
    </p>
    <div class="hero-cta reveal reveal-4">
      <a
        class="btn btn-amber"
        href={waLink(whatsapps[0].intl)}
        target="_blank"
        rel="noopener"
      >
        <Icon name="whatsapp" size={19} /> Solicitar cotización
      </a>
      <a class="btn btn-ghost" href="/catalogo">
        <Icon name="doc" size={18} /> Ver catálogo
      </a>
    </div>
  </div>
</section>

<!-- Banda ámbar: mensaje clave -->
<div class="hero-band">
  <div class="container hero-band-inner">
    <p>Reducimos el costo total de tu abastecimiento industrial</p>
    <ul class="hero-norms" aria-label="Normativas que cumplen nuestros productos">
      {normativas.map((n) => <li>{n}</li>)}
    </ul>
  </div>
</div>

<style>
  .hero {
    position: relative;
    display: grid;
    align-items: center;
    min-height: clamp(500px, 72vh, 660px);
    padding-block: var(--space-3xl);
    overflow: hidden;
    isolation: isolate;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
        100deg,
        rgba(12, 14, 18, 0.94) 0%,
        rgba(12, 14, 18, 0.78) 38%,
        rgba(12, 14, 18, 0.35) 68%,
        rgba(12, 14, 18, 0.15) 100%
      ),
      linear-gradient(0deg, rgba(12, 14, 18, 0.5), transparent 40%);
  }
  .hero-inner {
    max-width: 680px;
  }
  .hero-title {
    font-size: var(--text-display);
    letter-spacing: -0.005em;
    margin: var(--space-md) 0 var(--space-md);
    text-wrap: balance;
  }
  .hero .lead {
    color: var(--text-muted);
    max-width: 56ch;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
  }

  .hero-band {
    background: var(--amber);
    color: var(--on-amber);
  }
  .hero-band-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm) var(--space-lg);
    padding-block: var(--space-md);
  }
  .hero-band p {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: clamp(0.92rem, 0.85rem + 0.4vw, 1.15rem);
  }
  .hero-norms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .hero-norms li {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.55rem;
    border: 1px solid rgba(23, 17, 10, 0.28);
    border-radius: var(--radius-xs);
  }
</style>
