---
import { Image } from "astro:assets";
import heroMina from "../assets/img/hero-mina-sunset.png";
import heroIzajeObra from "../assets/img/hero-izaje-obra.jpg";
import equipo from "../assets/img/equipo.jpg";
import { whatsapps, waLink } from "../data/site";
import { normativas } from "../data/content";
import Icon from "../components/Icon.astro";

const slides = [
  {
    img: heroMina,
    eyebrow: "Suministros industriales · Arequipa · Perú",
    title: 'El socio <span class="amber">estratégico</span> para tu empresa',
    lead: "Abastecemos minería, construcción, petróleo, gas, energía e industria. Representantes de Bekaert y distribuidores de marcas líderes, con entregas a todo el Perú.",
    cta: { label: "Ver productos", href: "/productos", icon: "arrow" },
  },
  {
    img: heroIzajeObra,
    eyebrow: "Elementos de izaje certificados",
    title: 'Izaje con respaldo <span class="amber">Bekaert</span>',
    lead: "Estrobos SuperLoop, cadenas grado 8 y eslingas Strongloop con Carga Límite de Trabajo certificada bajo norma ASME B30.9, OSHA y ASTM.",
    cta: { label: "Más información", href: "/lineas", icon: "arrow" },
  },
  {
    img: equipo,
    eyebrow: "Un solo proveedor",
    title: 'Todo tu abastecimiento, <span class="amber">en un solo lugar</span>',
    lead: "Herramientas, seguridad, izaje, transmisión de potencia, contención de derrames y ferretería. Más de 60 tipos de producto listos para cotizar.",
    cta: { label: "Ubícanos", href: "/contacto", icon: "pin" },
  },
];
---

<section id="inicio" class="hero on-dark" aria-label="Presentación" data-hero>
  <div class="hero-slides">
    {
      slides.map((s, i) => (
        <div class="hero-slide" data-slide data-active={i === 0 ? "" : undefined}>
          {/* Fondo desenfocado que rellena el espacio (sin barras vacías) */}
          <div class="hero-fill" aria-hidden="true">
            <Image src={s.img} alt="" widths={[640, 1024]} sizes="100vw" loading={i === 0 ? "eager" : "lazy"} />
          </div>
          {/* Imagen completa, sin recortar */}
          <div class="hero-photo" aria-hidden="true">
            <Image
              src={s.img}
              alt=""
              widths={[768, 1280, 1920]}
              sizes="100vw"
              loading={i === 0 ? "eager" : "lazy"}
              fetchpriority={i === 0 ? "high" : undefined}
            />
          </div>
          <div class="hero-scrim" aria-hidden="true" />
          <div class="container">
            <div class="hero-inner">
              {i === 0 ? (
                <h1 id="hero-h" class="hero-title" set:html={s.title} />
              ) : (
                <p class="hero-title" set:html={s.title} />
              )}
              <p class="lead">{s.lead}</p>
              <div class="hero-cta">
                <a class="btn btn-amber hero-btn" href={s.cta.href}>{s.cta.label}</a>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <div class="hero-dots" role="tablist" aria-label="Elegir presentación">
    {
      slides.map((_, i) => (
        <button
          class="hero-dot"
          data-dot
          data-active={i === 0 ? "" : undefined}
          type="button"
          aria-label={`Ir a la presentación ${i + 1}`}
        />
      ))
    }
  </div>
</section>

<!-- Banda ámbar: mensaje clave -->
<div class="hero-band">
  <div class="container hero-band-inner">
    <p>Reducimos el costo total de tu abastecimiento industrial</p>
    <ul class="hero-norms" aria-label="Normativas que cumplen nuestros productos">
      {normativas.map((n) => <li>{n}</li>)}
    </ul>
  </div>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-hero]");
    if (!root) return;
    const slides = [...root.querySelectorAll("[data-slide]")];
    const dots = [...root.querySelectorAll("[data-dot]")];
    if (slides.length < 2) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let idx = 0;
    let timer = null;
    const DELAY = 7000;

    const go = (n) => {
      idx = (n + slides.length) % slides.length;
      slides.forEach((s, i) =>
        i === idx ? s.setAttribute("data-active", "") : s.removeAttribute("data-active")
      );
      dots.forEach((d, i) =>
        i === idx ? d.setAttribute("data-active", "") : d.removeAttribute("data-active")
      );
    };
    const start = () => {
      if (reduce) return;
      stop();
      timer = window.setInterval(() => go(idx + 1), DELAY);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
      timer = null;
    };

    dots.forEach((d, i) =>
      d.addEventListener("click", () => {
        go(i);
        start();
      })
    );
    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);
    start();
  })();
</script>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: clamp(520px, 76vh, 720px);
    overflow: hidden;
    isolation: isolate;
    background: var(--ink);
  }
  /* Todos los slides se apilan en la misma celda de grid */
  .hero-slides {
    grid-area: 1 / 1;
    display: grid;
  }
  .hero-slide {
    grid-area: 1 / 1;
    position: relative;
    display: grid;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 600ms var(--ease-out), visibility 600ms var(--ease-out);
  }
  .hero-slide[data-active] {
    opacity: 1;
    visibility: visible;
  }

  /* Fondo: misma imagen ampliada y desenfocada para rellenar los costados */
  .hero-fill {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-fill img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.15);
    filter: blur(22px) brightness(0.45) saturate(1.1);
  }

  /* Imagen principal: completa, sin recorte */
  .hero-photo {
    position: absolute;
    inset: 0;
    z-index: -1;
    display: grid;
    place-items: center;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    transition: transform 7200ms ease-out;
    transform: scale(1.001);
  }
  .hero-slide[data-active] .hero-photo img {
    transform: scale(1.06);
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
        ellipse 90% 80% at 50% 50%,
        rgba(var(--ink-rgb), 0.7) 0%,
        rgba(var(--ink-rgb), 0.82) 100%
      ),
      linear-gradient(0deg, rgba(var(--ink-rgb), 0.55), transparent 55%);
  }

  .hero-inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
    padding-block: var(--space-3xl);
  }
  .hero-title {
    font-size: var(--text-display);
    letter-spacing: -0.005em;
    margin: var(--space-md) 0 var(--space-md);
    text-wrap: balance;
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 1.02;
  }
  .hero .lead {
    color: var(--text-muted);
    max-width: 60ch;
    margin-inline: auto;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
  }
  .hero-btn {
    border-radius: 999px;
    --btn-pad-x: 1.8rem;
  }

  .hero-dots {
    position: absolute;
    left: 50%;
    bottom: 1.2rem;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 3;
  }
  .hero-dot {
    width: 30px;
    height: 5px;
    border: none;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    padding: 0;
    transition: background var(--dur) var(--ease-out), width var(--dur) var(--ease-out);
  }
  .hero-dot[data-active] {
    background: var(--amber);
    width: 44px;
  }

  .hero-band {
    background: var(--amber);
    color: var(--on-amber);
  }
  .hero-band-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm) var(--space-lg);
    padding-block: var(--space-md);
  }
  .hero-band p {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: clamp(0.92rem, 0.85rem + 0.4vw, 1.15rem);
  }
  .hero-norms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .hero-norms li {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.55rem;
    border: 1px solid rgba(23, 17, 10, 0.28);
    border-radius: var(--radius-xs);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slide {
      transition: none;
    }
    .hero-photo img,
    .hero-slide[data-active] .hero-photo img {
      transition: none;
      transform: none;
    }
  }
</style>
