---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Icon from "../components/Icon.astro";
import Guia from "../components/Guia.astro";
import { importaciones, guias } from "../data/content";

/* Carga de todas las imágenes de la carpeta importaciones para poder
   referenciarlas por nombre desde los datos. */
const imgs = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/img/importaciones/*.{jpg,jpeg,png,webp}",
  { eager: true }
);
const img = (name: string) =>
  imgs[`../assets/img/importaciones/${name}.jpg`]?.default;

const { lineas, otras, intro } = importaciones;
---

<section id="importaciones" class="section" aria-label="Líneas de importación">
  <div class="container">
    <p class="imp-intro reveal">{intro}</p>

    <div class="imp-toc reveal">
      {
        lineas.map((l) => (
          <a href={`#${l.id}`} class="imp-chip">
            {l.nombre}
          </a>
        ))
      }
      <a href="#otras" class="imp-chip">{otras.nombre}</a>
    </div>

    {
      lineas.map((l, i) => (
        <article id={l.id} class={`imp-line reveal ${i % 2 ? "is-flip" : ""}`}>
          <div class="imp-media">
            {img(l.img) && (
              <Image
                src={img(l.img)!}
                alt={l.nombre}
                widths={[420, 720, 1000]}
                sizes="(min-width: 900px) 42vw, 100vw"
                class="imp-img"
              />
            )}
            {l.img2 && img(l.img2) && (
              <Image
                src={img(l.img2)!}
                alt={`${l.nombre} — detalle`}
                widths={[420, 720]}
                sizes="(min-width: 900px) 42vw, 100vw"
                class="imp-img"
              />
            )}
          </div>

          <div class="imp-body">
            <p class="eyebrow">{l.marca}</p>
            <h2>{l.nombre}</h2>
            <p class="imp-tag">{l.tagline}</p>
            <p class="imp-desc">{l.resumen}</p>

            {"bullets" in l && l.bullets && (
              <ul class="imp-bullets">
                {l.bullets.map((b) => (
                  <li>
                    <Icon name="check" size={16} /> {b}
                  </li>
                ))}
              </ul>
            )}

            {"tipos" in l && l.tipos && (
              <ul class="imp-tipos">
                {l.tipos.map((t) => (
                  <li>
                    {"hex" in t && t.hex && (
                      <span class="imp-dot" style={`background:${t.hex}`} />
                    )}
                    <div>
                      <strong>
                        {t.n}
                        {"color" in t && t.color ? ` · ${t.color}` : ""}
                      </strong>
                      <span>{t.d}</span>
                    </div>
                  </li>
                ))}
              </ul>
            )}

            {"formatos" in l && l.formatos && (
              <div class="imp-formatos">
                <span class="imp-formatos-h">Formatos:</span>
                {l.formatos.map((f) => (
                  <span class="imp-badge">{f}</span>
                ))}
              </div>
            )}

            {"aplicaciones" in l && l.aplicaciones && (
              <div class="imp-formatos">
                <span class="imp-formatos-h">Aplicaciones:</span>
                {l.aplicaciones.map((f) => (
                  <span class="imp-badge">{f}</span>
                ))}
              </div>
            )}

            {"certs" in l && l.certs && (
              <ul class="imp-certs">
                {l.certs.map((c) => (
                  <li>
                    <Icon name="shield" size={16} /> {c}
                  </li>
                ))}
              </ul>
            )}
          </div>

          <div class="imp-wide">
            {"galeria" in l && l.galeria && (
              <div class="imp-galeria">
                <span class="imp-formatos-h">
                  {"galeriaTitulo" in l && l.galeriaTitulo
                    ? l.galeriaTitulo
                    : "En operación"}:
                </span>
                <div class="imp-galeria-grid">
                  {l.galeria.map((g) =>
                    img(g.img) ? (
                      <figure class="imp-gal-item">
                        <Image
                          src={img(g.img)!}
                          alt={g.cap}
                          widths={[220, 360, 520]}
                          sizes="(min-width: 900px) 22vw, 45vw"
                          class="imp-gal-img"
                        />
                        <figcaption>{g.cap}</figcaption>
                      </figure>
                    ) : null
                  )}
                </div>
              </div>
            )}

            {"estilos" in l && l.estilos && (
              <div class="imp-galeria">
                <span class="imp-formatos-h">Estilos y colores:</span>
                <div class="imp-galeria-grid">
                  {l.estilos.map((g) =>
                    img(g.img) ? (
                      <figure class="imp-gal-item">
                        <Image
                          src={img(g.img)!}
                          alt={g.cap}
                          widths={[220, 360, 520]}
                          sizes="(min-width: 900px) 22vw, 45vw"
                          class="imp-gal-img"
                        />
                        <figcaption>{g.cap}</figcaption>
                      </figure>
                    ) : null
                  )}
                </div>
              </div>
            )}

            {"personalizacion" in l && l.personalizacion && (
              <p class="imp-personaliza">
                <Icon name="wrench" size={16} /> {l.personalizacion}
              </p>
            )}

            {"stock" in l && l.stock && (
              <div class="imp-stock">
                <span class="imp-stock-badge">En stock</span>
                <h3 class="imp-stock-title">{l.stock.title}</h3>
                <p class="imp-stock-medida">{l.stock.medida}</p>
                <ul class="imp-stock-specs">
                  {l.stock.specs.map((s) => (
                    <li>
                      <Icon name="check" size={15} /> {s}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {"tabla" in l && l.tabla && (
              <div class="imp-table-wrap">
                <p class="imp-table-cap">{l.tabla.caption}</p>
                <div class="imp-scroll">
                  <table class="imp-table">
                    <thead>
                      <tr>
                        {l.tabla.cols.map((c) => (
                          <th>{c}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody>
                      {l.tabla.rows.map((r) => (
                        <tr>
                          {r.map((cell, ci) => (
                            <td class={ci === 0 ? "is-first" : ""}>{cell}</td>
                          ))}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {guias.filter((g) => g.producto === l.id).length > 0 && (
              <div class="imp-guias">
                {guias
                  .filter((g) => g.producto === l.id)
                  .map((g) => (
                    <Guia guia={g} />
                  ))}
              </div>
            )}
          </div>
        </article>
      ))
    }

    <article id="otras" class="imp-otras reveal">
      <div>
        <p class="eyebrow">Importación bajo pedido</p>
        <h2>{otras.nombre}</h2>
        <p>{otras.resumen}</p>
      </div>
      <Icon name="gear" size={64} class="imp-otras-ic" />
    </article>
  </div>
</section>

<style>
  .imp-intro {
    max-width: 68ch;
    font-size: var(--text-lg);
    color: var(--text-muted);
    margin-bottom: 1.6rem;
  }
  .imp-toc {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--line);
  }
  .imp-chip {
    font-family: var(--font-display);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    color: var(--text-muted);
    transition: border-color var(--dur) var(--ease-out),
      color var(--dur) var(--ease-out), background var(--dur) var(--ease-out);
  }
  .imp-chip:hover {
    border-color: var(--amber);
    color: var(--on-amber);
    background: var(--amber);
  }

  /* — Bloque de línea — */
  .imp-line {
    display: grid;
    gap: clamp(1.6rem, 4vw, 3rem);
    align-items: start;
    padding-block: clamp(2.5rem, 5vw, 4rem);
    scroll-margin-top: 90px;
  }
  .imp-line + .imp-line {
    border-top: 1px solid var(--line);
  }

  /* — Media (imágenes apiladas) — */
  .imp-media {
    display: grid;
    gap: 1rem;
    align-self: start;
    align-content: start;
  }
  .imp-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    background: #fff;
    box-shadow: var(--shadow-card);
  }
  .imp-img:only-child {
    aspect-ratio: 5 / 4;
  }

  /* — Franja de ancho completo (galerías, tabla, stock, guías) — */
  .imp-wide {
    display: grid;
    gap: 1.3rem;
  }
  .imp-wide > * {
    margin-bottom: 0;
  }

  /* — Cuerpo — */
  .imp-body h2 {
    font-size: clamp(1.4rem, 1.1rem + 1.3vw, 2rem);
    margin: 0.5rem 0 0.4rem;
  }
  .imp-tag {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text);
    font-size: 1.02rem;
    margin-bottom: 0.8rem;
  }
  .imp-desc {
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 1.2rem;
  }

  .imp-bullets {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1.3rem;
  }
  .imp-bullets li {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    color: var(--text-muted);
    font-size: 0.94rem;
    line-height: 1.5;
  }
  .imp-bullets :global(svg) {
    color: var(--amber);
    flex: none;
    margin-top: 4px;
  }

  .imp-tipos {
    display: grid;
    gap: 0.7rem;
    margin-bottom: 1.3rem;
  }
  .imp-tipos li {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--steel-900);
  }
  .imp-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    flex: none;
    margin-top: 3px;
    border: 1px solid var(--line-strong);
  }
  .imp-tipos strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.92rem;
    margin-bottom: 0.15rem;
  }
  .imp-tipos span {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .imp-formatos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.3rem;
  }
  .imp-formatos-h {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.76rem;
    color: var(--text-dim);
    margin-right: 0.2rem;
  }
  .imp-badge {
    font-size: 0.8rem;
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-xs);
    color: var(--amber-deep);
    background: var(--amber-tint);
  }

  /* — Galería en operación — */
  .imp-galeria {
    margin-bottom: 1.3rem;
  }
  .imp-galeria .imp-formatos-h {
    display: block;
    margin-bottom: 0.6rem;
  }
  .imp-galeria-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.7rem;
  }
  .imp-gal-item {
    margin: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--steel-900);
  }
  .imp-gal-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    background: #fff;
  }
  .imp-gal-item figcaption {
    padding: 0.5rem 0.6rem;
    font-size: 0.78rem;
    line-height: 1.35;
    color: var(--text-muted);
  }
  @media (min-width: 900px) {
    .imp-galeria-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* — Nota de personalización — */
  .imp-personaliza {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-muted);
    padding: 0.85rem 1rem;
    margin-bottom: 1.3rem;
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius);
    background: var(--steel-900);
  }
  .imp-personaliza :global(svg) {
    color: var(--amber-deep);
    flex: none;
    margin-top: 3px;
  }

  /* — Callout de stock — */
  .imp-stock {
    margin-bottom: 1.3rem;
    padding: clamp(1.1rem, 3vw, 1.5rem);
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-lg);
    background: linear-gradient(120deg, var(--amber-tint), transparent 75%);
  }
  .imp-stock-badge {
    display: inline-block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: var(--amber);
    color: var(--on-amber);
    margin-bottom: 0.6rem;
  }
  .imp-stock-title {
    font-size: clamp(1.1rem, 1rem + 0.7vw, 1.4rem);
    margin: 0 0 0.2rem;
  }
  .imp-stock-medida {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.7rem;
  }
  .imp-stock-specs {
    display: grid;
    gap: 0.4rem;
  }
  .imp-stock-specs li {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .imp-stock-specs :global(svg) {
    color: var(--amber-deep);
    flex: none;
    margin-top: 3px;
  }

  /* — Tabla — */
  .imp-table-cap {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }
  .imp-scroll {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .imp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.76rem;
    min-width: 440px;
  }
  .imp-table th {
    background: var(--ink);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.64rem;
    text-align: left;
    padding: 0.35rem 0.55rem;
  }
  .imp-table td {
    padding: 0.32rem 0.55rem;
    border-top: 1px solid var(--line);
    color: var(--text-muted);
  }
  .imp-table td.is-first {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text);
  }
  .imp-table tbody tr:nth-child(even) {
    background: var(--steel-800);
  }

  .imp-certs {
    display: grid;
    gap: 0.5rem;
    margin-top: 1.3rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
  }
  .imp-certs li {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
    font-size: 0.86rem;
    color: var(--text-muted);
  }
  .imp-certs :global(svg) {
    color: var(--amber-deep);
    flex: none;
    margin-top: 3px;
  }

  .imp-guias {
    margin-top: 1.4rem;
  }

  /* — Otras (equipos y aceros) — */
  .imp-otras {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: clamp(2rem, 4vw, 3rem);
    padding: clamp(1.6rem, 3vw, 2.4rem);
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-lg);
    background: linear-gradient(120deg, var(--amber-tint), transparent 70%);
    scroll-margin-top: 90px;
  }
  .imp-otras h2 {
    font-size: clamp(1.3rem, 1.1rem + 1vw, 1.7rem);
    margin: 0.6rem 0 0.5rem;
  }
  .imp-otras p {
    color: var(--text-muted);
    max-width: 64ch;
  }
  .imp-otras :global(.imp-otras-ic) {
    color: var(--amber);
    flex: none;
    opacity: 0.85;
  }

  @media (min-width: 900px) {
    .imp-line {
      grid-template-columns: minmax(0, 0.82fr) minmax(0, 1fr);
      column-gap: clamp(2rem, 4vw, 3.4rem);
      row-gap: 1.8rem;
    }
    .imp-media {
      grid-column: 1;
      grid-row: 1;
    }
    .imp-body {
      grid-column: 2;
      grid-row: 1;
    }
    .imp-line.is-flip .imp-media {
      grid-column: 2;
    }
    .imp-line.is-flip .imp-body {
      grid-column: 1;
    }
    .imp-wide {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 560px) {
    .imp-otras :global(.imp-otras-ic) {
      display: none;
    }
  }
</style>
