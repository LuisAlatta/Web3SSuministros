---
import { Image } from "astro:assets";
import hardpadTop from "../assets/img/hardpad-top.jpeg";
import hardpadStack from "../assets/img/hardpad-stack.jpeg";
import { izaje, derrames, hardpad } from "../data/content";
import { whatsapps, waLink } from "../data/site";
import Icon from "../components/Icon.astro";
---

<section id="lineas" class="section plate" aria-label="Líneas destacadas">
  <div class="container">
    <!-- Línea: Elementos de Izaje (Bridon-Bekaert) -->
    <article class="lin izaje-block reveal">
      <div class="iz-intro">
        <div class="iz-intro-text">
          <span class="lin-tag">{izaje.brand}</span>
          <h3>{izaje.title}</h3>
          <p class="lin-intro">{izaje.intro}</p>
          <p class="iz-historia">{izaje.historia}</p>
          <div class="lin-actions">
            <a
              class="btn btn-amber"
              href={waLink(whatsapps[0].intl, "Hola 3S, quiero cotizar elementos de izaje (estrobos / cadenas / eslingas).")}
              target="_blank"
              rel="noopener"
            >
              <Icon name="whatsapp" size={18} /> Cotizar izaje
            </a>
            <a class="btn btn-ghost" href="/catalogos/elementos-de-izaje-bekaert.pdf" target="_blank" rel="noopener">
              <Icon name="download" size={18} /> Catálogo Bekaert
            </a>
          </div>
        </div>
        <aside class="iz-aside">
          <span class="izaje-num">5:1</span>
          <p>Factor de diseño certificado en estrobos SuperLoop</p>
          <div class="iz-norms">
            {izaje.normas.map((n) => <span class="norm-chip">{n}</span>)}
          </div>
          <span class="iz-presencia">
            <Icon name="globe" size={16} /> {izaje.presencia}
          </span>
        </aside>
      </div>

      <!-- Familias de izaje (acordeón) -->
      <div class="fam-list">
        {
          izaje.familias.map((f, i) => (
            <details class="fam" open={i === 0}>
              <summary>
                <span class="fam-name">{f.name}</span>
                <span class="fam-badges">
                  <span class="badge">{f.norm}</span>
                  <span class="badge badge-amber">Factor {f.factor}</span>
                </span>
                <span class="fam-chev" aria-hidden="true">
                  <Icon name="arrowdown" size={18} />
                </span>
              </summary>
              <div class="fam-body">
                <p class="fam-tag">{f.tagline}</p>
                <p class="fam-desc">{f.desc}</p>
                <ul class="fam-bul">
                  {f.bullets.map((b) => (
                    <li>
                      <Icon name="check" size={16} /> {b}
                    </li>
                  ))}
                </ul>

                {"tabla" in f && f.tabla && (
                  <figure class="wll">
                    <div class="wll-wrap">
                      <table>
                        <thead>
                          <tr>{f.tabla.cols.map((c) => <th>{c}</th>)}</tr>
                        </thead>
                        <tbody>
                          {f.tabla.rows.map((r) => (
                            <tr>
                              {r.map((cell, ci) => (
                                <td data-l={f.tabla.cols[ci]}>
                                  {ci === 0 ? <strong>{cell}</strong> : cell}
                                </td>
                              ))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                    <figcaption>{f.tabla.caption}</figcaption>
                  </figure>
                )}

                {"colores" in f && f.colores && (
                  <figure class="wll">
                    <div class="color-grid">
                      {f.colores.rows.map((c) => (
                        <div class="color-row">
                          <span class="swatch" style={`--sw:${c.hex}`} aria-hidden="true" />
                          <span class="c-name">{c.color}</span>
                          <span class="c-ancho">{c.ancho}</span>
                          <span class="c-wll">
                            {c.wll} <em>TM</em>
                          </span>
                        </div>
                      ))}
                    </div>
                    <figcaption>{f.colores.caption}</figcaption>
                  </figure>
                )}
              </div>
            </details>
          ))
        }
      </div>

      <!-- Accesorios + criterios de inspección -->
      <div class="iz-extra">
        <div class="iz-acc">
          <h4>{izaje.accesorios.title}</h4>
          <p>{izaje.accesorios.intro}</p>
          <ul class="acc-chips">
            {izaje.accesorios.items.map((a) => <li>{a}</li>)}
          </ul>
        </div>
        <div class="iz-insp">
          <h4><Icon name="shield" size={18} /> Inspección y criterios de descarte</h4>
          <div class="insp-grid">
            {
              izaje.inspeccion.map((g) => (
                <div class="insp-col">
                  <strong>{g.grupo}</strong>
                  <ul>
                    {g.puntos.map((p) => <li>{p}</li>)}
                  </ul>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </article>

    <!-- Línea: Contención de Derrames -->
    <article class="lin derrames-block reveal">
      <div class="der-head">
        <div>
          <span class="lin-tag">{derrames.brand}</span>
          <h3>{derrames.title}</h3>
          <p class="lin-intro">{derrames.intro}</p>
        </div>
        <a
          class="btn btn-amber"
          href={waLink(whatsapps[1].intl, "Hola 3S, quiero cotizar productos de contención de derrames (absorbentes / kits).")}
          target="_blank"
          rel="noopener"
        >
          <Icon name="whatsapp" size={18} /> Cotizar derrames
        </a>
      </div>

      <div class="der-grid">
        {
          derrames.productos.map((p) => (
            <div class="der-card">
              <span class="der-ic"><Icon name="shield" size={18} /></span>
              <strong>{p.name}</strong>
              <span>{p.desc}</span>
            </div>
          ))
        }
      </div>

      <div class="der-kits">
        {
          derrames.kits.map((k) => (
            <div class="kit">
              <h5>{k.size}</h5>
              <ul>
                {k.items.map((it) => (
                  <li>
                    <Icon name="check" size={15} /> {it}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </article>

    <!-- Línea: HARDPAD Crane -->
    <article class="lin hardpad reveal">
      <div class="hp-media">
        <Image
          src={hardpadTop}
          alt="Almohadilla HARDPAD Crane en UHMW para estabilizadores de grúa"
          widths={[360, 560, 760]}
          sizes="(min-width: 900px) 460px, 90vw"
          loading="lazy"
        />
        <Image
          class="hp-media-2"
          src={hardpadStack}
          alt="Almohadillas HARDPAD apiladas con asas de transporte"
          widths={[240, 360]}
          sizes="200px"
          loading="lazy"
        />
      </div>

      <div class="lin-text">
        <span class="lin-tag">{hardpad.brand}</span>
        <h3>{hardpad.title}</h3>
        <p class="lin-intro">{hardpad.intro}</p>
        <div class="hp-benefits">
          {
            hardpad.benefits.map((b) => (
              <div class="hp-benefit">
                <span class="hp-benefit-ic"><Icon name="check" size={16} /></span>
                <div>
                  <strong>{b.title}</strong>
                  <span>{b.desc}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </article>

    <!-- Tabla de especificaciones HARDPAD -->
    <div class="hp-specs reveal">
      <div class="hp-specs-head">
        <h4>Modelos y capacidades HARDPAD</h4>
        <a
          class="btn btn-amber btn-sm"
          href={waLink(whatsapps[1].intl, "Hola 3S, quiero cotizar almohadillas HARDPAD para grúa.")}
          target="_blank"
          rel="noopener"
        >
          <Icon name="whatsapp" size={16} /> Cotizar HARDPAD
        </a>
      </div>
      <div class="hp-table-wrap">
        <table>
          <thead>
            <tr>
              <th>Modelo</th>
              <th>Medida</th>
              <th>Alto</th>
              <th>Peso aprox.</th>
              <th>Capacidad de carga</th>
            </tr>
          </thead>
          <tbody>
            {
              hardpad.specs.map((s) => (
                <tr>
                  <td data-l="Modelo"><strong>{s.modelo}</strong></td>
                  <td data-l="Medida">{s.medida}</td>
                  <td data-l="Alto">{s.alto}</td>
                  <td data-l="Peso">{s.peso}</td>
                  <td data-l="Capacidad"><span class="ton">{s.carga}</span></td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="hp-note">
        Fabricadas en polietileno de ultra alto peso molecular (UHMW). Medidas y
        capacidades referenciales; consúltanos por requerimientos especiales.
      </p>
    </div>
  </div>
</section>

<style>
  .lin-head {
    margin-bottom: clamp(2.2rem, 4vw, 3.4rem);
  }
  .lin-head h2 {
    margin-top: 0.9rem;
  }
  .lin {
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, var(--steel-850), var(--steel-900));
    padding: clamp(1.6rem, 3.5vw, 3rem);
    margin-bottom: 1.4rem;
  }
  .lin-tag {
    display: inline-block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: 0.78rem;
    color: var(--amber);
    margin-bottom: 0.7rem;
  }
  .lin-text h3,
  .iz-intro-text h3,
  .der-head h3 {
    font-size: clamp(1.7rem, 1.2rem + 2vw, 2.6rem);
  }
  .lin-intro {
    color: var(--text-muted);
    margin: 1rem 0 1.4rem;
    max-width: 60ch;
  }
  .lin-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  /* ===== IZAJE ===== */
  .iz-intro {
    display: grid;
    gap: clamp(1.6rem, 3vw, 2.6rem);
  }
  .iz-historia {
    color: var(--text-dim);
    font-size: 0.94rem;
    margin: 0 0 1.6rem;
    max-width: 64ch;
    padding-left: 1rem;
    border-left: 2px solid var(--amber-line);
  }
  .iz-aside {
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-lg);
    background: linear-gradient(160deg, var(--amber-tint), transparent);
    padding: clamp(1.6rem, 3vw, 2.2rem);
    display: grid;
    align-content: center;
    text-align: center;
  }
  .izaje-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.5rem, 2rem + 6vw, 5.5rem);
    color: var(--amber);
    line-height: 0.9;
  }
  .iz-aside p {
    color: var(--text);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.92rem;
    margin: 0.7rem 0 1.2rem;
  }
  .iz-norms {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    margin-bottom: 1.1rem;
  }
  .norm-chip {
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--amber-deep);
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-xs);
    padding: 0.22rem 0.5rem;
  }
  .iz-presencia {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    justify-content: center;
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .iz-presencia :global(svg) {
    color: var(--amber);
    flex: none;
  }

  /* Familias — acordeón */
  .fam-list {
    margin-top: clamp(1.8rem, 3vw, 2.6rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--steel-900);
  }
  .fam + .fam {
    border-top: 1px solid var(--line);
  }
  .fam summary {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: clamp(1rem, 2.4vw, 1.4rem) clamp(1rem, 2.4vw, 1.6rem);
    cursor: pointer;
    list-style: none;
    transition: background var(--dur) var(--ease-out);
  }
  .fam summary::-webkit-details-marker {
    display: none;
  }
  .fam summary:hover {
    background: var(--steel-850);
  }
  .fam-name {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(1rem, 0.9rem + 0.5vw, 1.15rem);
    color: var(--text);
  }
  .fam-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-left: auto;
  }
  .badge {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.03em;
    color: var(--text-dim);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-xs);
    padding: 0.22rem 0.5rem;
    white-space: nowrap;
  }
  .badge-amber {
    color: var(--on-amber);
    background: var(--amber);
    border-color: var(--amber);
  }
  .fam-chev {
    flex: none;
    display: grid;
    place-items: center;
    color: var(--text-dim);
    transition: transform var(--dur) var(--ease-out), color var(--dur) var(--ease-out);
  }
  .fam[open] .fam-chev {
    transform: rotate(180deg);
    color: var(--amber);
  }
  .fam-body {
    padding: 0 clamp(1rem, 2.4vw, 1.6rem) clamp(1.2rem, 2.6vw, 1.8rem);
  }
  .fam-tag {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.8rem;
    color: var(--amber);
    margin-bottom: 0.5rem;
  }
  .fam-desc {
    color: var(--text-muted);
    max-width: 64ch;
    margin-bottom: 1rem;
  }
  .fam-bul {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1.3rem;
  }
  .fam-bul li {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    color: var(--text-muted);
    font-size: 0.92rem;
  }
  .fam-bul li :global(svg) {
    color: var(--amber);
    flex: none;
    margin-top: 3px;
  }

  /* Tabla WLL */
  .wll {
    margin: 0;
  }
  .wll-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .wll figcaption {
    margin-top: 0.7rem;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  /* Eslingas — código de colores */
  .color-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .color-row {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 0.7rem;
    background: var(--steel-900);
    padding: 0.6rem 0.9rem;
  }
  .swatch {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--sw);
    border: 1px solid rgba(255, 255, 255, 0.25);
    flex: none;
  }
  .c-name {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.86rem;
    color: var(--text);
  }
  .c-ancho {
    font-size: 0.86rem;
    color: var(--text-dim);
  }
  .c-wll {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--amber);
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .c-wll em {
    font-style: normal;
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  /* Accesorios + inspección */
  .iz-extra {
    margin-top: 1.4rem;
    display: grid;
    gap: 1.4rem;
  }
  .iz-acc h4,
  .iz-insp h4 {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 1.05rem;
    margin-bottom: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .iz-insp h4 :global(svg) {
    color: var(--amber);
  }
  .iz-acc p {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin-bottom: 0.9rem;
  }
  .acc-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .acc-chips li {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.82rem;
    color: var(--text);
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-xs);
    transition: border-color var(--dur) var(--ease-out), color var(--dur) var(--ease-out);
  }
  .acc-chips li:hover {
    border-color: var(--amber);
    color: var(--amber-deep);
  }
  .insp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .insp-col {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--steel-900);
    padding: 1rem 1.1rem;
  }
  .insp-col strong {
    display: block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.86rem;
    color: var(--amber-deep);
    margin-bottom: 0.6rem;
  }
  .insp-col ul {
    display: grid;
    gap: 0.4rem;
  }
  .insp-col li {
    position: relative;
    padding-left: 1rem;
    color: var(--text-muted);
    font-size: 0.86rem;
  }
  .insp-col li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--amber);
  }

  /* ===== DERRAMES ===== */
  .der-head {
    display: grid;
    gap: 1.2rem;
    margin-bottom: 1.6rem;
  }
  .der-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .der-card {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--steel-900);
    padding: 1.2rem;
    transition: transform var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  .der-card:hover {
    transform: translateY(-3px);
    border-color: var(--amber-line);
  }
  .der-ic {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius);
    background: var(--amber-tint);
    color: var(--amber);
    margin-bottom: 0.8rem;
  }
  .der-card strong {
    display: block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.98rem;
    margin-bottom: 0.35rem;
  }
  .der-card > span:last-child {
    color: var(--text-dim);
    font-size: 0.88rem;
  }
  .der-kits {
    margin-top: 1.4rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .kit {
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-lg);
    background: linear-gradient(160deg, var(--amber-tint), transparent 80%);
    padding: 1.3rem;
  }
  .kit h5 {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 1.05rem;
    color: var(--amber);
    margin-bottom: 0.8rem;
  }
  .kit ul {
    display: grid;
    gap: 0.45rem;
  }
  .kit li {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .kit li :global(svg) {
    color: var(--amber);
    flex: none;
    margin-top: 3px;
  }

  /* ===== HARDPAD ===== */
  .hp-media {
    position: relative;
  }
  .hp-media > :global(img:first-child) {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line-strong);
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .hp-media-2 {
    position: absolute;
    right: -10px;
    bottom: -22px;
    width: 42%;
    border-radius: var(--radius);
    border: 3px solid var(--steel-850);
    box-shadow: var(--shadow-card);
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }
  .hardpad {
    display: grid;
    gap: clamp(1.6rem, 3vw, 2.6rem);
  }
  .hp-benefits {
    display: grid;
    gap: 0.9rem 1.4rem;
    grid-template-columns: 1fr;
    margin-top: 0.4rem;
  }
  .hp-benefit {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
  }
  .hp-benefit-ic {
    flex: none;
    width: 26px;
    height: 26px;
    margin-top: 2px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--amber-tint);
    color: var(--amber);
  }
  .hp-benefit strong {
    display: block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.98rem;
  }
  .hp-benefit > div span {
    color: var(--text-dim);
    font-size: 0.88rem;
  }

  /* Specs table */
  .hp-specs {
    margin-top: 1.4rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--steel-900);
    padding: clamp(1.3rem, 3vw, 2rem);
  }
  .hp-specs-head {
