---
import { Image } from "astro:assets";
import hardpadTop from "../assets/img/hardpad-top.jpeg";
import hardpadStack from "../assets/img/hardpad-stack.jpeg";
import { lineaIzaje, hardpad } from "../data/content";
import { whatsapps, waLink } from "../data/site";
import Icon from "../components/Icon.astro";
---

<section id="lineas" class="section plate" aria-labelledby="lin-h">
  <div class="container">
    <header class="lin-head reveal">
      <p class="eyebrow">Líneas destacadas</p>
      <h2 id="lin-h">Productos que marcan la <span class="amber">diferencia</span></h2>
    </header>

    <!-- Línea: Elementos de Izaje -->
    <article class="lin izaje reveal">
      <div class="lin-text">
        <span class="lin-tag">{lineaIzaje.brand}</span>
        <h3>{lineaIzaje.title}</h3>
        <p class="lin-intro">{lineaIzaje.intro}</p>
        <ul class="lin-feats">
          {
            lineaIzaje.features.map((f) => (
              <li>
                <Icon name="check" size={17} /> {f}
              </li>
            ))
          }
        </ul>
        <div class="lin-actions">
          <a
            class="btn btn-amber"
            href={waLink(whatsapps[0].intl, "Hola 3S, quiero cotizar elementos de izaje (estrobos / cadenas / eslingas).")}
            target="_blank"
            rel="noopener"
          >
            <Icon name="whatsapp" size={18} /> Cotizar izaje
          </a>
          <a class="btn btn-ghost" href="/catalogos/elementos-de-izaje-bekaert.pdf" target="_blank" rel="noopener">
            <Icon name="download" size={18} /> Catálogo Bekaert
          </a>
        </div>
      </div>
      <div class="lin-aside" aria-hidden="true">
        <span class="izaje-num">5:1</span>
        <p>Factor de diseño certificado en estrobos SuperLoop</p>
        <span class="izaje-norm">ASME B30.9 · OSHA · ASTM</span>
      </div>
    </article>

    <!-- Línea: HARDPAD Crane -->
    <article class="lin hardpad reveal">
      <div class="hp-media">
        <Image
          src={hardpadTop}
          alt="Almohadilla HARDPAD Crane en UHMW para estabilizadores de grúa"
          widths={[360, 560, 760]}
          sizes="(min-width: 900px) 460px, 90vw"
          loading="lazy"
        />
        <Image
          class="hp-media-2"
          src={hardpadStack}
          alt="Almohadillas HARDPAD apiladas con asas de transporte"
          widths={[240, 360]}
          sizes="200px"
          loading="lazy"
        />
      </div>

      <div class="lin-text">
        <span class="lin-tag">{hardpad.brand}</span>
        <h3>{hardpad.title}</h3>
        <p class="lin-intro">{hardpad.intro}</p>
        <div class="hp-benefits">
          {
            hardpad.benefits.map((b) => (
              <div class="hp-benefit">
                <strong>{b.title}</strong>
                <span>{b.desc}</span>
              </div>
            ))
          }
        </div>
      </div>
    </article>

    <!-- Tabla de especificaciones HARDPAD -->
    <div class="hp-specs reveal">
      <div class="hp-specs-head">
        <h4>Modelos y capacidades HARDPAD</h4>
        <a
          class="btn btn-amber btn-sm"
          href={waLink(whatsapps[1].intl, "Hola 3S, quiero cotizar almohadillas HARDPAD para grúa.")}
          target="_blank"
          rel="noopener"
        >
          <Icon name="whatsapp" size={16} /> Cotizar HARDPAD
        </a>
      </div>
      <div class="hp-table-wrap">
        <table>
          <thead>
            <tr>
              <th>Modelo</th>
              <th>Medida</th>
              <th>Alto</th>
              <th>Peso aprox.</th>
              <th>Capacidad de carga</th>
            </tr>
          </thead>
          <tbody>
            {
              hardpad.specs.map((s) => (
                <tr>
                  <td data-l="Modelo"><strong>{s.modelo}</strong></td>
                  <td data-l="Medida">{s.medida}</td>
                  <td data-l="Alto">{s.alto}</td>
                  <td data-l="Peso">{s.peso}</td>
                  <td data-l="Capacidad"><span class="ton">{s.carga}</span></td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="hp-note">
        Fabricadas en polietileno de ultra alto peso molecular (UHMW). Medidas y
        capacidades referenciales; consúltanos por requerimientos especiales.
      </p>
    </div>
  </div>
</section>

<style>
  .lin-head {
    margin-bottom: clamp(2.2rem, 4vw, 3.4rem);
  }
  .lin-head h2 {
    margin-top: 0.9rem;
  }
  .lin {
    display: grid;
    gap: clamp(1.6rem, 3vw, 2.6rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, var(--steel-850), var(--steel-900));
    padding: clamp(1.6rem, 3.5vw, 3rem);
    margin-bottom: 1.4rem;
  }
  .lin-tag {
    display: inline-block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: 0.78rem;
    color: var(--amber);
    margin-bottom: 0.7rem;
  }
  .lin-text h3 {
    font-size: clamp(1.7rem, 1.2rem + 2vw, 2.6rem);
  }
  .lin-intro {
    color: var(--text-muted);
    margin: 1rem 0 1.4rem;
    max-width: 60ch;
  }
  .lin-feats {
    display: grid;
    gap: 0.7rem;
    margin-bottom: 1.8rem;
  }
  .lin-feats li {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    color: var(--text-muted);
  }
  .lin-feats li :global(svg) {
    color: var(--amber);
    flex: none;
    margin-top: 4px;
  }
  .lin-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  /* Izaje aside */
  .lin-aside {
    border: 1px solid var(--amber-line);
    border-radius: var(--radius-lg);
    background: linear-gradient(160deg, var(--amber-tint), transparent);
    padding: clamp(1.6rem, 3vw, 2.4rem);
    display: grid;
    align-content: center;
    text-align: center;
  }
  .izaje-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.5rem, 2rem + 6vw, 6rem);
    color: var(--amber);
    line-height: 0.9;
  }
  .lin-aside p {
    color: var(--text);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin: 0.8rem 0 1rem;
  }
  .izaje-norm {
    font-size: 0.82rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  /* HARDPAD media */
  .hp-media {
    position: relative;
  }
  .hp-media > :global(img:first-child) {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line-strong);
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .hp-media-2 {
    position: absolute;
    right: -10px;
    bottom: -22px;
    width: 42%;
    border-radius: var(--radius);
    border: 3px solid var(--steel-850);
    box-shadow: var(--shadow-card);
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }
  .hp-benefits {
    display: grid;
    gap: 0.9rem 1.4rem;
    grid-template-columns: 1fr;
    margin-top: 0.4rem;
  }
  .hp-benefit {
    border-left: 2px solid var(--amber);
    padding-left: 0.9rem;
  }
  .hp-benefit strong {
    display: block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.98rem;
  }
  .hp-benefit span {
    color: var(--text-dim);
    font-size: 0.88rem;
  }

  /* Specs table */
  .hp-specs {
    margin-top: 1.4rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--steel-900);
    padding: clamp(1.3rem, 3vw, 2rem);
  }
  .hp-specs-head {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.2rem;
  }
  .hp-specs-head h4 {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.2rem;
    letter-spacing: 0.02em;
  }
  .hp-table-wrap {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 520px;
  }
  thead th {
    text-align: left;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
    color: var(--text-dim);
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--line-strong);
  }
  tbody td {
    padding: 0.85rem 0.9rem;
    border-bottom: 1px solid var(--line);
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  tbody tr:hover {
    background: var(--steel-850);
  }
  tbody td strong {
    font-family: var(--font-display);
    letter-spacing: 0.03em;
    color: var(--text);
  }
  .ton {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--amber);
    background: var(--amber-tint);
    border-radius: var(--radius-xs);
    padding: 0.2rem 0.6rem;
  }
  .hp-note {
    margin-top: 1.1rem;
    font-size: 0.84rem;
    color: var(--text-dim);
  }
  .btn-sm {
    --btn-pad-y: 0.55rem;
    --btn-pad-x: 1rem;
    font-size: 0.82rem;
  }

  @media (min-width: 900px) {
    .izaje {
      grid-template-columns: 1.5fr 1fr;
      align-items: center;
    }
    .hardpad {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: center;
    }
    .hp-benefits {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Tabla responsive en móvil (stacked) */
  @media (max-width: 560px) {
    table,
    thead,
    tbody,
    tr,
    td {
      display: block;
      min-width: 0;
    }
    thead {
      display: none;
    }
    tbody tr {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      margin-bottom: 0.8rem;
      padding: 0.4rem 0.2rem;
    }
    tbody td {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      border-bottom: 1px solid var(--line);
    }
    tbody td:last-child {
      border-bottom: none;
    }
    tbody td::before {
      content: attr(data-l);
      font-family: var(--font-display);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-size: 0.78rem;
      color: var(--text-dim);
    }
  }
</style>
