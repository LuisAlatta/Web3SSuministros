---
import { novedades } from "../data/content";
import { formatFecha } from "../lib/format";
import Icon from "../components/Icon.astro";

const posts = [...novedades].sort((a, b) => (a.fecha < b.fecha ? 1 : -1));
---

<section id="novedades" class="section" aria-label="Novedades y recursos">
  <div class="container">
    <div class="nov-grid">
      {
        posts.map((p, i) => (
          <article class={`nov-card reveal reveal-${(i % 3) + 1}`}>
            <div class="nov-card-top">
              <span class="nov-cat">{p.categoria}</span>
              <time datetime={p.fecha}>{formatFecha(p.fecha)}</time>
            </div>
            <h3>
              <a href={`/novedades/${p.slug}`}>{p.title}</a>
            </h3>
            <p>{p.resumen}</p>
            <a class="nov-link" href={`/novedades/${p.slug}`}>
              Leer más <Icon name="arrow" size={16} />
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .nov-head {
    max-width: 720px;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .nov-head h2 {
    margin: 0.9rem 0 1.1rem;
  }
  .nov-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }
  .nov-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--steel-900);
    padding: clamp(1.3rem, 3vw, 1.8rem);
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  .nov-card:hover {
    transform: translateY(-4px);
    border-color: var(--amber-line);
  }
  .nov-card-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.9rem;
  }
  .nov-cat {
    font-family: var(--font-display);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--on-amber);
    background: var(--amber);
    border-radius: var(--radius-xs);
    padding: 0.22rem 0.55rem;
  }
  .nov-card-top time {
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .nov-card h3 {
    font-size: 1.2rem;
    line-height: 1.3;
    margin-bottom: 0.6rem;
  }
  .nov-card h3 a {
    color: var(--text);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nov-card h3 a:hover {
    color: var(--amber);
  }
  .nov-card p {
    color: var(--text-muted);
    font-size: 0.92rem;
    flex: 1;
    margin-bottom: 1.1rem;
  }
  .nov-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.8rem;
    color: var(--amber);
  }
  .nov-link :global(svg) {
    transition: transform var(--dur) var(--ease-out);
  }
  .nov-card:hover .nov-link :global(svg) {
    transform: translateX(4px);
  }

  @media (min-width: 640px) {
    .nov-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 960px) {
    .nov-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
