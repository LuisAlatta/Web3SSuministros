---
import { Image } from "astro:assets";
import equipo from "../assets/img/equipo.jpg";
import { stats } from "../data/content";
import Icon from "../components/Icon.astro";
---

<section class="section" aria-labelledby="intro-h">
  <div class="container intro">
    <div class="intro-text reveal">
      <p class="eyebrow">La empresa</p>
      <h2 id="intro-h">
        Tu socio en <span class="amber">abastecimiento industrial</span> en Arequipa
      </h2>
      <p class="lead">
        En 3S Suministros desarrollamos soluciones de abastecimiento que se
        adaptan a la necesidad de cada cliente. Representamos y distribuimos
        marcas reconocidas que cumplen normativas nacionales e internacionales,
        y somos socios estratégicos de las principales empresas y proyectos del
        país.
      </p>
      <a class="btn btn-ghost" href="/nosotros">
        Conócenos <Icon name="arrow" size={18} />
      </a>
    </div>

    <div class="intro-visual reveal reveal-2">
      <Image
        src={equipo}
        alt="Equipo de ingenieros de 3S Suministros en planta industrial"
        widths={[420, 640, 820]}
        sizes="(min-width: 760px) 44vw, 90vw"
        loading="lazy"
      />
    </div>
  </div>

  <div class="container">
    <dl class="intro-stats reveal">
      {
        stats.map((s) => (
          <div class="intro-stat">
            <dt data-count>{s.value}</dt>
            <dd>{s.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .intro {
    display: grid;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .intro-text h2 {
    margin: var(--space-sm) 0 var(--space-md);
  }
  .intro-text .btn {
    margin-top: var(--space-lg);
  }
  .intro-visual {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .intro-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  .intro-stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .intro-stat {
    background: var(--steel-900);
    padding: clamp(1.3rem, 3vw, 1.9rem);
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }
  .intro-stat dt {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.9rem, 1.4rem + 1.8vw, 2.6rem);
    color: var(--amber-deep);
    line-height: 1;
    flex: none;
  }
  .intro-stat dd {
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  @media (min-width: 760px) {
    .intro {
      grid-template-columns: 1.05fr 0.95fr;
    }
    .intro-stats {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
